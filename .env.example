# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# NEXT_PUBLIC_SITE_URL=https://www.tudominio.com

# =============================================================================
# Email — Hostinger (correo profesional en tu dominio)
# =============================================================================
# En hPanel: Email → elige la cuenta → ver detalles / configuración del cliente.
# Usuario SMTP = dirección completa (ej. ventas@nutrielys.com) y la contraseña de esa casilla.
#
# Opción recomendada (TLS):
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
#
# Alternativa (SSL directo): descomenta y ajusta puerto; el código marca secure si puerto es 465
# SMTP_PORT=465
# SMTP_SECURE=true
#
SMTP_USER=ventas@tudominio.com
SMTP_PASS=la-contraseña-de-esa-casilla

# Remitente que verán en el correo (misma cuenta o alias permitido por Hostinger):
SMTP_FROM_EMAIL=Nutrielys <ventas@tudominio.com>

# Aquí recibes contacto, newsletter y avisos de pedidos (pon tu correo profesional Hostinger):
CONTACT_RECEIVER_EMAIL=ventas@tudominio.com
